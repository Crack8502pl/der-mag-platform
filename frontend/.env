# Frontend Environment Variables

# Backend API URL
# Zostaw puste aby automatycznie użyć window.location.origin/api
# (frontend i backend na tym samym porcie)
# VITE_API_BASE_URL=

# Aby ograniczyć zużycie RAM przez proces Vite, ustaw NODE_OPTIONS w shellu lub skrypcie:
# NODE_OPTIONS=--max-old-space-size=256 npm run dev
