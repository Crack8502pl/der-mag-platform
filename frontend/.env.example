# Frontend Environment Variables

# Backend API URL
# Zostaw puste aby automatycznie użyć window.location.origin/api
# Lub ustaw jawnie dla danego środowiska:
# VITE_API_BASE_URL=https://api.grover.pl/api
VITE_API_BASE_URL=

# Map Tiles Configuration
# Ustaw na 'true' aby używać backendowego proxy z cache'em (zalecane dla produkcji)
VITE_USE_TILE_PROXY=false
